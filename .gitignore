# Environment variables (never commit secrets)
.env

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# Archivos temporales de screenshots exportados (generados, no commiteados)
.temp-screenshots/

# Local cache (copy-html renders, preview hydration — never commit)
.cache/

# AI workflow documentation (regenerable)
AI_WORKFLOW.md

# AI Assistants and Agents (recreados por bun run agents:sync)
.claude/
.opencode/
.cursor/
.agent/
.agents/
.codex/
.github/skills
AGENTS.md
CLAUDE.md

# Build output (reproducible via bun run build)
dist/
