{
  "name": "Hero Section",
  "description": "Sección hero con título, subtítulo y botón de CTA. Soporta múltiples variantes",
  "component": "src/partials/organisms/hero",
  "variants": [
    {
      "id": "v1",
      "name": "Sky Gradient",
      "description": "Fondo con gradiente azul cielo"
    },
    {
      "id": "v2",
      "name": "Dark Modern",
      "description": "Fondo oscuro con diseño moderno"
    }
  ],
  "props": {
    "variant": {
      "type": "select",
      "default": "v1",
      "label": "Variante",
      "options": [
        {
          "value": "v1",
          "label": "Sky Gradient"
        },
        {
          "value": "v2",
          "label": "Dark Modern"
        }
      ]
    },
    "title": {
      "type": "string",
      "default": "Bienvenido a Mi Empresa",
      "label": "Título principal",
      "required": true
    },
    "subtitle": {
      "type": "string",
      "default": "Descubre todo lo que podemos hacer por ti",
      "label": "Subtítulo",
      "required": true
    },
    "buttonText": {
      "type": "string",
      "default": "Explorar ahora",
      "label": "Texto del botón"
    },
    "buttonUrl": {
      "type": "string",
      "default": "https://ejemplo.com",
      "label": "URL del botón"
    },
    "showButton": {
      "type": "boolean",
      "default": true,
      "label": "Mostrar botón CTA"
    }
  }
}
