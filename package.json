{
  "name": "vite-mhb-email",
  "version": "1.0.0",
  "description": "Email template development toolkit integrating Maizzle, Handlebars and Vite",
  "keywords": [
    "email",
    "maizzle",
    "handlebars",
    "vite",
    "template",
    "tailwindcss"
  ],
  "private": true,
  "author": "Frank-0511",
  "contributors": [
    {
      "name": "Frank-0511",
      "email": "frank05111996@gmail.com",
      "url": "https://github.com/Frank-0511"
    }
  ],
  "homepage": "https://github.com/Frank-0511/vite-mhb-email",
  "bugs": {
    "url": "https://github.com/Frank-0511/vite-mhb-email/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Frank-0511/vite-mhb-email"
  },
  "packageManager": "yarn@4.13.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "yarn": ">=4"
  },
  "scripts": {
    "dev": "vite",
    "build": "yarn lint && node scripts/build/build.js",
    "check-size": "node scripts/build/check-html-size.js",
    "cli": "node scripts/cli.js",
    "lint": "yarn lint:html && yarn lint:js && yarn lint:md && yarn lint:json",
    "lint:html": "htmlhint \"src/templates/**/*.html\"",
    "lint:js": "eslint scripts/ vite.config.js",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:json": "node scripts/build/validate-json.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "scripts/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "vite.config.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.html": [
      "htmlhint",
      "prettier --write"
    ],
    "src/templates/*/data.json": [
      "node scripts/validate-json.js",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@maizzle/framework": "5.5.0",
    "autoprefixer": "10.4",
    "eslint": "9.22.0",
    "eslint-config-prettier": "10.1.1",
    "fs-extra": "11.3.4",
    "glob": "13.0.6",
    "globals": "16.0.0",
    "htmlhint": "1.9.2",
    "husky": "9.1.5",
    "lint-staged": "15.2.10",
    "maizzle": "0.0.1",
    "markdownlint-cli2": "0.17.2",
    "nodemailer": "6.10.0",
    "postcss": "8.4",
    "prettier": "3.5.3",
    "puppeteer-core": "^24.40.0",
    "tailwindcss": "3.4.17",
    "vite": "7.3.1"
  },
  "resolutions": {
    "css-select": "4.3.0"
  },
  "dependencies": {
    "handlebars": "4.7.8",
    "lucide": "^0.577.0"
  }
}
