{
  "name": "vite-mhb-email",
  "version": "1.0.0",
  "description": "Email template development toolkit integrating Maizzle, Handlebars and Vite",
  "keywords": [
    "email",
    "maizzle",
    "handlebars",
    "vite",
    "template",
    "tailwindcss"
  ],
  "private": true,
  "author": "Frank-0511",
  "contributors": [
    {
      "name": "Frank-0511",
      "email": "frank05111996@gmail.com",
      "url": "https://github.com/Frank-0511"
    }
  ],
  "homepage": "https://github.com/Frank-0511/vite-mhb-email",
  "bugs": {
    "url": "https://github.com/Frank-0511/vite-mhb-email/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Frank-0511/vite-mhb-email"
  },
  "packageManager": "bun@1.2.2",
  "type": "module",
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "bun run lint && bun scripts/build/build.js",
    "check-size": "bun scripts/build/check-html-size.js",
    "validate-email": "bun scripts/build/validate-email-html.js",
    "cli": "bun scripts/cli.js",
    "lint": "bun run lint:html && bun run lint:js && bun run lint:md && bun run lint:json",
    "lint:html": "htmlhint \"src/templates/**/*.html\"",
    "lint:js": "eslint scripts/ vite.config.js",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#analysis_results.md\"",
    "lint:json": "bun scripts/build/validate-json.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "scripts/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "vite.config.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.html": [
      "htmlhint",
      "prettier --write"
    ],
    "src/templates/*/data.json": [
      "bun scripts/validate-json.js",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@maizzle/framework": "5.5.0",
    "autoprefixer": "10.5.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "fs-extra": "11.3.4",
    "glob": "13.0.6",
    "globals": "17.5.0",
    "htmlhint": "1.9.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "maizzle": "1.1.0",
    "markdownlint-cli2": "0.22.1",
    "nodemailer": "8.0.7",
    "postcss": "8.5.12",
    "prettier": "3.8.3",
    "puppeteer-core": "24.42.0",
    "tailwindcss": "3.4.19",
    "vite": "8.0.10"
  },
  "dependencies": {
    "handlebars": "4.7.9",
    "lucide": "^1.14.0"
  }
}
