# ─── Mailtrap Sandbox ─────────────────────────────────────────────────────────
# Obtené tu token en: https://mailtrap.io → API Tokens
MAILTRAP_API_TOKEN=your_api_token_here

# Tu Inbox ID aparece en la URL del inbox: mailtrap.io/inboxes/{INBOX_ID}
MAILTRAP_INBOX_ID=your_inbox_id_here

# Remitente por defecto (se puede personalizar al momento del envío)
MAILTRAP_FROM_EMAIL=no-reply@example.com
MAILTRAP_FROM_NAME=vite-mhb-email

# Destinatario por defecto (se puede personalizar al momento del envío)
MAILTRAP_TO_EMAIL=test@example.com
MAILTRAP_TO_NAME=Test User

# ─── Gmail SMTP (para enviar a mail-tester.com) ──────────────────────────────
# Necesitás un App Password (NO tu contraseña normal de Google):
# https://myaccount.google.com/apppasswords
GMAIL_USER=tu@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Nombre remitente por defecto para envíos vía Gmail
SMTP_FROM_NAME=vite-mhb-email

# Dirección de mail-tester por defecto (se actualiza con cada test)
MAILTESTER_TO_EMAIL=test-9165uwur1@srv1.mail-tester.com

# ─── Destinatarios por defecto para validación en vivo ───────────────────────
TEST_GMAIL_TO=tu@gmail.com
TEST_OUTLOOK_TO=tu@outlook.com
TEST_APPLE_TO=tu@icloud.com
